{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "imagehub",
  "version": "0.8.0",
  "identifier": "fr.redious.imagehub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ImageHub",
        "width": 880,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1MTlGQkZDMUUxQTJCNTYKUldSV0t4b2UvUHNaTmRDZEF6OFFqSWZlZFhydjZxRUo0YUtGMUJvUmlOVWtJcUR1K2hQSzhtNC8K",
      "endpoints": [
        "https://github.com/DevRedious/imagehub/releases/latest/download/latest.json"
      ]
    }
  }
}
